{
  "info": {
    "_postman_id": "d762c698-e7a9-4402-8aee-8396476d62d2",
    "name": "NestJS Backend Internship Challenge",
    "description": "Alur lokal: health, registrasi, login, Project CRUD, Task CRUD, lalu negative cases. Import bersama local.postman_environment.json.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Liveness",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Readiness",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/health/ready"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('database up', () => pm.expect(pm.response.json().database).to.eql('up'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman User\",\n  \"email\": \"postman.user@example.com\",\n  \"password\": \"example-password-123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.environment.set('userId', body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman.user@example.com\",\n  \"password\": \"example-password-123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.environment.set('accessToken', body.accessToken);",
                  "pm.environment.set('userId', body.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.expect(pm.response.json().id).to.eql(pm.environment.get('userId'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Project\",\n  \"description\": \"Project created from the collection\",\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/projects"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.environment.set('projectId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/projects?page=1&limit=20&sortBy=createdAt&sortOrder=desc"
          }
        },
        {
          "name": "Get Project Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/projects/{{projectId}}"
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Postman Project\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/projects/{{projectId}}"
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/projects/{{projectId}}"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Task\",\n  \"status\": \"todo\",\n  \"priority\": \"medium\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/projects/{{projectId}}/tasks"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.environment.set('taskId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/projects/{{projectId}}/tasks?page=1&limit=20"
          }
        },
        {
          "name": "Get Task",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/projects/{{projectId}}/tasks/{{taskId}}"
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"done\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/projects/{{projectId}}/tasks/{{taskId}}"
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/projects/{{projectId}}/tasks/{{taskId}}"
          }
        }
      ]
    },
    {
      "name": "Negative Cases",
      "description": "Ownership menggunakan 404 untuk resource privat milik pengguna lain. Jalankan flow dengan akun kedua untuk memverifikasi isolasi.",
      "item": [
        {
          "name": "No Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/projects"
          }
        },
        {
          "name": "Invalid Token",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "invalid-token", "type": "string" }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/projects"
          }
        },
        {
          "name": "Invalid DTO",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"\"\n}" },
            "url": "{{baseUrl}}/api/v1/projects"
          }
        },
        {
          "name": "Unknown Property",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Invalid Project\",\n  \"ownerId\": \"00000000-0000-4000-8000-000000000000\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/projects"
          }
        },
        {
          "name": "Project Not Found",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/projects/00000000-0000-4000-8000-000000000000"
          }
        },
        {
          "name": "Task Not Found",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/projects/{{projectId}}/tasks/00000000-0000-4000-8000-000000000000"
          }
        }
      ]
    }
  ]
}
