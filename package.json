{
  "name": "nestjs-backend-internship-challenge",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "docs:validate": "node scripts/validate-postman.mjs",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"docs/api/**/*.md\" \"docs/database/**/*.md\" \"docs/operations/**/*.md\" \"docs/architecture/**/*.md\" \"docs/adr/**/*.md\" \"docs/postman/*.json\" \"scripts/*.mjs\" \".github/**/*.yml\" \"*.{json,mjs,yml,yaml}\" \".prettierrc\" \"README.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"docs/api/**/*.md\" \"docs/database/**/*.md\" \"docs/operations/**/*.md\" \"docs/architecture/**/*.md\" \"docs/adr/**/*.md\" \"docs/postman/*.json\" \"scripts/*.mjs\" \".github/**/*.yml\" \"*.{json,mjs,yml,yaml}\" \".prettierrc\" \"README.md\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:integration": "jest --config ./test/jest-integration.json --runInBand",
    "verify": "npm run build && npm run format:check && npm run lint && npm run typecheck && npm test -- --runInBand && npm run docs:validate",
    "verify:full": "npm run verify && npm run test:cov -- --runInBand && npm run test:e2e -- --detectOpenHandles && npm run test:integration -- --detectOpenHandles",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate src/database/migrations/InitialSchema -d src/database/data-source.ts",
    "migration:create": "npm run typeorm -- migration:create src/database/migrations/NewMigration",
    "migration:run": "npm run typeorm -- migration:run -d src/database/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/database/data-source.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/database/data-source.ts",
    "database:start": "docker compose -f compose.database.yml up -d",
    "database:stop": "docker compose -f compose.database.yml down",
    "database:status": "docker compose -f compose.database.yml ps",
    "database:logs": "docker compose -f compose.database.yml logs postgres",
    "redis:start": "docker compose -f compose.redis.yml up -d",
    "redis:stop": "docker compose -f compose.redis.yml down",
    "redis:status": "docker compose -f compose.redis.yml ps",
    "redis:logs": "docker compose -f compose.redis.yml logs redis",
    "dependencies:start": "docker compose -f compose.database.yml -f compose.redis.yml up -d",
    "dependencies:status": "docker compose -f compose.database.yml -f compose.redis.yml ps",
    "stack:build": "docker compose -f compose.yml build",
    "stack:migrate": "docker compose -f compose.yml run --rm migrate",
    "stack:start": "docker compose -f compose.yml up -d app",
    "stack:status": "docker compose -f compose.yml ps",
    "stack:logs": "docker compose -f compose.yml logs app",
    "stack:stop": "docker compose -f compose.yml down"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "joi": "^18.2.1",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 50,
        "branches": 52,
        "functions": 39,
        "lines": 49
      }
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
